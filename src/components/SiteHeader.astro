---
import { Image } from "astro:assets";
import { site } from "@/data/site.ts";
import { getDictionary, getLocalizedPath } from "@/i18n/utils.ts";
import type { Lang } from "@/i18n/types.ts";
import logo from "@/assets/brand/logo.png";

interface Props {
  currentPath?: string;
  lang?: Lang;
}

const { currentPath = "/", lang = "en" } = Astro.props as Props;
const t = getDictionary(lang);
const otherLang: Lang = lang === "en" ? "es" : "en";
const langTogglePath = getLocalizedPath(currentPath, otherLang);

const isActive = (href = "") => {
  if (href === getLocalizedPath("/", lang)) return currentPath === href;
  return currentPath.startsWith(href);
};

const basePaths = ["/", "/menu", "/bakery", "/delivery", "/catering", "/gallery", "/contact"] as const;
const navItems = basePaths.map((base) => ({
  href: getLocalizedPath(base, lang),
  label: t.nav[
    (base === "/" ? "home" : base.slice(1)) as keyof typeof t.nav
  ],
}));
---

<nav class="sticky top-0 z-50 border-b border-line bg-base/80 backdrop-blur-md" aria-label="Main navigation">
  <div class="mx-auto flex h-16 max-w-screen-xl items-center justify-between px-6">
    <a href={getLocalizedPath("/", lang)} class="flex items-center gap-2.5 font-serif text-xl italic tracking-tight" aria-label={`${site.name} home`}>
      <Image src={logo} alt="" class="h-10 w-10 rounded-full object-cover" widths={[40, 80]} sizes="40px" />
      {site.name}
    </a>
    <div class="hidden items-center gap-6 text-sm lg:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "transition-colors hover:text-accent",
              isActive(item.href) ? "text-ink" : "text-faded",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>
    <div class="flex items-center gap-3">
      <a
        href={langTogglePath}
        class="inline-flex h-11 items-center rounded-full px-4 text-[11px] font-medium uppercase tracking-[0.15em] text-faded ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
        aria-label={t.header.langSwitchLabel}
        hreflang={otherLang}
      >
        {t.header.langSwitchTo}
      </a>
      <a
        href={site.phone.href}
        class="hidden items-center gap-2 rounded-full bg-ink px-4 py-2 text-[11px] font-medium uppercase tracking-[0.15em] text-[var(--color-base)] transition-colors hover:bg-accent sm:inline-flex"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        {t.header.callNow}
      </a>
      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full text-ink transition-colors hover:text-accent lg:hidden"
        aria-label={t.header.openMenu}
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-mobile-menu-open
      >
        <span class="sr-only">{t.header.openMenu}</span>
        <span class="flex w-4 flex-col gap-1.5" aria-hidden="true">
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
        </span>
      </button>
    </div>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden h-dvh overflow-hidden bg-base text-ink lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile menu"
  data-mobile-menu
>
    <div class="flex h-full flex-col px-6 pb-6 pt-5">
      <div class="flex h-11 items-center justify-between">
        <a href={getLocalizedPath("/", lang)} class="flex items-center gap-2.5 font-serif text-xl italic tracking-tight" aria-label={`${site.name} home`} data-mobile-menu-link>
          <Image src={logo} alt="" class="h-10 w-10 rounded-full object-cover" widths={[40, 80]} sizes="40px" />
          {site.name}
        </a>
        <button
          type="button"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full text-ink transition-colors hover:text-accent"
          aria-label={t.header.closeMenu}
          data-mobile-menu-close
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M6 6l12 12"></path>
            <path d="M18 6L6 18"></path>
          </svg>
        </button>
      </div>

      <div class="flex min-h-0 flex-1 flex-col gap-5 overflow-y-auto pt-7">
        <div class="space-y-2.5">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "block font-serif text-4xl leading-none transition-colors hover:text-accent",
                  isActive(item.href) ? "text-ink" : "text-faded",
                ]}
                aria-current={isActive(item.href) ? "page" : undefined}
                data-mobile-menu-link
              >
                {item.label}
              </a>
            ))
          }
          <a
            href={langTogglePath}
            hreflang={otherLang}
            class="inline-flex items-center gap-2 pt-1 text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-accent"
            data-mobile-menu-link
          >
            {t.header.langSwitchLabel}: {t.header.langSwitchTo}
          </a>
        </div>

        <a
          href={site.phone.href}
          class="group block rounded-[min(1vw,12px)] bg-paper p-6 ring-1 ring-transparent transition-colors hover:ring-accent"
          data-mobile-menu-link
        >
          <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{t.header.callNow}</p>
          <p class="mt-2 font-serif text-3xl leading-none text-accent">{site.phone.display}</p>
          <p class="mt-3 text-sm leading-relaxed text-faded">
            {site.hours[0].days[lang]}: {site.hours[0].hours}
          </p>
        </a>

        <div class="mt-auto space-y-2 text-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{t.header.visit}</p>
          <a href={site.mapsUrl} target="_blank" rel="noopener noreferrer" class="block transition-colors hover:text-accent" data-mobile-menu-link>
            {site.address.full}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const menu = document.querySelector("[data-mobile-menu]");
    const openButton = document.querySelector("[data-mobile-menu-open]");
    const closeButton = document.querySelector("[data-mobile-menu-close]");

    if (!menu || !openButton || !closeButton) return;

    const focusableSelector = [
      "a[href]",
      "button:not([disabled])",
      "input:not([disabled])",
      "select:not([disabled])",
      "textarea:not([disabled])",
      '[tabindex]:not([tabindex="-1"])',
    ].join(",");
    let lastFocusedElement;

    function getFocusable() {
      return Array.from(menu.querySelectorAll(focusableSelector)).filter((element) => {
        return element instanceof HTMLElement && element.offsetParent !== null;
      });
    }

    function lockScroll() {
      document.documentElement.style.overflow = "hidden";
      document.body.style.overflow = "hidden";
    }

    function unlockScroll() {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    }

    function openMenu() {
      lastFocusedElement = document.activeElement;
      menu.classList.remove("hidden");
      openButton.setAttribute("aria-expanded", "true");
      lockScroll();
      closeButton.focus({ preventScroll: true });
    }

    function closeMenu({ restoreFocus = true } = {}) {
      menu.classList.add("hidden");
      openButton.setAttribute("aria-expanded", "false");
      unlockScroll();

      if (restoreFocus && lastFocusedElement instanceof HTMLElement) {
        lastFocusedElement.focus({ preventScroll: true });
      }
    }

    openButton.addEventListener("click", openMenu);
    closeButton.addEventListener("click", () => closeMenu());

    menu.querySelectorAll("[data-mobile-menu-link]").forEach((link) => {
      link.addEventListener("click", () => closeMenu({ restoreFocus: false }));
    });

    document.addEventListener("keydown", (event) => {
      if (menu.classList.contains("hidden")) return;

      if (event.key === "Escape") {
        event.preventDefault();
        closeMenu();
        return;
      }

      if (event.key !== "Tab") return;

      const focusable = getFocusable();
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (!first || !last) return;

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 1024px)").matches && !menu.classList.contains("hidden")) {
        closeMenu({ restoreFocus: false });
      }
    });
  })();
</script>
