---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site.ts";
import { getDictionary, getLocalizedPath } from "@/i18n/utils.ts";
import type { Lang } from "@/i18n/types.ts";
import bakeryHero from "@/assets/gallery/pandeyema.jpg";
import doughHands from "@/assets/stock/dough-hands.jpg";
import cakeBirthday from "@/assets/gallery/pastel-de-cumpleanos.png";
import cakeFruit from "@/assets/gallery/pastel-de-cumpleanos-2.png";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props as Props;
const t = getDictionary(lang);
const path = (base: string) => getLocalizedPath(base, lang);
const photo = (en: string, es: string) => (lang === "es" ? `Foto: ${es}` : `Photo: ${en}`);
---

<BaseLayout lang={lang} title={t.meta.bakery.title} description={t.meta.bakery.description}>
  <main id="main-content">
  <section class="mx-auto max-w-screen-xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
    <p class="mb-6 flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
      <span class="inline-block h-px w-8 bg-ink/40"></span>
      {t.bakery.kicker}
    </p>
    <h1 class="max-w-[20ch] text-balance font-serif text-5xl leading-[0.95] md:text-7xl">
      {t.bakery.heading} <span class="italic text-accent">{t.bakery.headingAccent}</span>
    </h1>
    <p class="mt-8 max-w-[60ch] text-lg leading-relaxed text-faded">{t.bakery.intro}</p>
  </section>

  <section class="relative w-full">
    <Image
      src={bakeryHero}
      alt={photo("Fresh bread & bakery case", "Vitrina de la panadería y pan fresco")}
      class="h-[45vh] w-full object-cover md:h-[60vh]"
      widths={[768, 1200, 1920]}
      sizes="100vw"
    />
  </section>

  <section class="mx-auto mt-24 grid max-w-screen-xl gap-10 px-6 md:mt-32 md:grid-cols-12 md:gap-16">
    <div class="md:col-span-5">
      <p class="mb-6 text-[11px] uppercase tracking-[0.3em] text-faded">{t.bakery.section2Kicker}</p>
      <h2 class="text-balance font-serif text-3xl leading-[1.02] md:text-5xl">{t.bakery.section2Heading}</h2>
    </div>
    <div class="space-y-6 leading-relaxed text-faded md:col-span-6 md:col-start-7">
      <p>{t.bakery.section2Body}</p>
    </div>
  </section>

  <section class="mx-auto mt-24 max-w-screen-xl border-t border-line px-6 pt-12 md:mt-32">
    <p class="mb-12 text-[11px] uppercase tracking-[0.3em] text-faded">{t.bakery.blocksKicker}</p>
    <div class="grid gap-x-8 gap-y-12 md:grid-cols-3">
      {
        t.bakery.blocks.map((block) => (
          <div class="space-y-3">
            <p class="text-[10px] uppercase tracking-[0.3em] text-faded tabular-nums">{block.n}</p>
            <h3 class="font-serif text-2xl">{block.h}</h3>
            <p class="text-sm leading-relaxed text-faded">{block.p}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mt-24 md:mt-32">
    <div class="mx-auto grid max-w-screen-2xl items-center gap-10 px-6 md:grid-cols-12 md:gap-16">
      <div class="aspect-[3/4] overflow-hidden rounded-[min(1vw,12px)] md:col-span-5">
        <Image
          src={doughHands}
          alt={photo("Hands preparing bread dough", "Manos preparando masa de pan")}
          class="h-full w-full object-cover"
          widths={[480, 768, 1080]}
          sizes="(min-width: 768px) 40vw, 100vw"
        />
      </div>
      <div class="space-y-8 md:col-span-6 md:col-start-7">
        <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
          <span class="inline-block h-px w-8 bg-ink/40"></span>
          {t.bakery.specialtyKicker}
        </p>
        <h2 class="text-balance font-serif text-3xl leading-[1.15] md:text-4xl">
          {t.bakery.specialtyHeading} <span class="italic text-accent">{t.bakery.specialtyHeadingAccent}</span>
        </h2>
        <div class="space-y-3 border-t border-line pt-6 text-sm leading-relaxed text-faded">
          <p>{t.bakery.specialtyBody}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-24 max-w-screen-xl px-6 md:mt-32">
    <div class="grid items-center gap-10 md:grid-cols-12 md:gap-16">
      <div class="space-y-6 md:col-span-5">
        <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
          <span class="inline-block h-px w-8 bg-ink/40"></span>
          {t.bakery.cakesKicker}
        </p>
        <h2 class="text-balance font-serif text-3xl leading-[1.15] md:text-4xl">
          {t.bakery.cakesHeading} <span class="italic text-accent">{t.bakery.cakesHeadingAccent}</span>
        </h2>
        <p class="max-w-[48ch] leading-relaxed text-faded">{t.bakery.cakesBody}</p>
        <a
          href={site.phone.href}
          class="inline-flex items-center gap-3 rounded-full bg-ink px-6 py-3.5 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
        >
          {t.common.callNow} →
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4 md:col-span-7 md:gap-6">
        <div class="aspect-square overflow-hidden rounded-[min(1vw,12px)]">
          <Image
            src={cakeBirthday}
            alt={photo("Custom birthday cake", "Pastel de cumpleaños personalizado")}
            class="h-full w-full object-cover"
            widths={[320, 480, 640]}
            sizes="(min-width: 768px) 30vw, 50vw"
          />
        </div>
        <div class="aspect-square overflow-hidden rounded-[min(1vw,12px)]">
          <Image
            src={cakeFruit}
            alt={photo("Custom cake with fresh fruit", "Pastel personalizado con fruta fresca")}
            class="h-full w-full object-cover"
            widths={[320, 480, 640]}
            sizes="(min-width: 768px) 30vw, 50vw"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto mt-24 max-w-screen-xl border-y border-line px-6 py-12 md:mt-32">
    <div class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
      {
        t.bakery.stats.map((stat) => (
          <div class="space-y-2">
            <p class="font-serif text-4xl tabular-nums md:text-5xl">{stat.n}</p>
            <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{stat.l}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section id="studio" class="mx-auto mb-32 mt-12 max-w-screen-xl px-6 md:mt-16">
    <div class="grid items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-7">
        <h2 class="max-w-[22ch] text-balance font-serif text-3xl leading-[1.02] md:text-5xl">
          {t.bakery.endingHeading}
        </h2>
      </div>
      <div class="flex flex-col flex-wrap gap-4 sm:flex-row md:col-span-5 md:justify-end">
        <a
          href={path("/menu")}
          class="inline-flex items-center justify-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
        >
          {t.common.viewMenu} →
        </a>
        <a
          href={site.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 rounded-full px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-ink ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
        >
          {t.common.getDirections} →
        </a>
        <a
          href={site.phone.href}
          class="inline-flex items-center justify-center gap-3 rounded-full px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-ink ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
        >
          {t.common.callNow}
        </a>
      </div>
    </div>
  </section>
  </main>
</BaseLayout>
