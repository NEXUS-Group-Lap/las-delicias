---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site.ts";
import { getDictionary, getLocalizedPath } from "@/i18n/utils.ts";
import type { Lang } from "@/i18n/types.ts";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props as Props;
const t = getDictionary(lang);
const path = (base: string) => getLocalizedPath(base, lang);
---

<BaseLayout lang={lang} title={t.meta.contact.title} description={t.meta.contact.description}>
  <main id="main-content">
  <section class="mx-auto max-w-screen-xl px-6 pb-12 pt-20 md:pb-16 md:pt-28">
    <p class="mb-6 flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
      <span class="inline-block h-px w-8 bg-ink/40"></span>
      {t.contact.kicker}
    </p>
    <h1 class="max-w-[20ch] text-balance font-serif text-5xl leading-[0.95] md:text-6xl">
      {t.contact.heading} <span class="italic text-accent">{t.contact.headingAccent}</span>
    </h1>
  </section>

  <div class="mx-auto max-w-screen-xl px-6 pb-32">
    <div class="grid grid-cols-1 gap-16 md:grid-cols-2">
      <div class="space-y-10">
        <div>
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.contact.addressTitle}</h2>
          <a href={site.mapsUrl} target="_blank" rel="noopener noreferrer" class="mt-3 block font-serif text-2xl leading-snug transition-colors hover:text-accent">
            {site.name}
            <br />
            {site.address.street}
            <br />
            {site.address.city}, {site.address.region} {site.address.postalCode}
          </a>
          <a
            href={site.mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] text-ink underline underline-offset-4 transition-colors hover:text-accent"
          >
            {t.common.getDirections} →
          </a>
        </div>

        <div>
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.contact.phoneTitle}</h2>
          <a href={site.phone.href} class="mt-3 block font-serif text-3xl transition-colors hover:text-accent">
            {site.phone.display}
          </a>
        </div>

        <div>
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.contact.emailTitle}</h2>
          <a href={site.email.href} class="mt-3 block text-lg transition-colors hover:text-accent">
            {site.email.display}
          </a>
        </div>

        <div>
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.contact.followTitle}</h2>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent">Facebook — {site.facebookName}</a></li>
            <li><a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent">Instagram — {site.social.instagramHandle}</a></li>
            <li><a href={site.social.tiktok} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent">TikTok — {site.social.tiktokHandle}</a></li>
          </ul>
        </div>
      </div>

      <div class="space-y-10">
        <div>
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.contact.hoursTitle}</h2>
          <dl class="mt-4 space-y-3 border-t border-line pt-4 text-sm">
            {
              site.hours.map((entry) => (
                <div class="flex justify-between border-b border-line py-2">
                  <dt>{entry.days[lang]}</dt>
                  <dd class="tabular-nums text-faded">{entry.hours}</dd>
                </div>
              ))
            }
          </dl>
        </div>

        <div class="rounded-[min(1vw,12px)] bg-paper p-8">
          <h2 class="font-serif text-2xl">{t.contact.quickActionsTitle}</h2>
          <div class="mt-6 flex flex-col gap-3">
            <a
              href={site.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 rounded-full bg-ink px-6 py-3.5 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
            >
              {t.common.getDirections} →
            </a>
            <a
              href={site.phone.href}
              class="inline-flex items-center justify-center gap-3 rounded-full px-6 py-3.5 text-[11px] font-medium uppercase tracking-[0.2em] text-ink ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
            >
              {t.common.callNow}
            </a>
            <a
              href={path("/menu")}
              class="inline-flex items-center justify-center gap-3 rounded-full px-6 py-3.5 text-[11px] font-medium uppercase tracking-[0.2em] text-ink ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
            >
              {t.common.viewMenu}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
  </main>
</BaseLayout>
