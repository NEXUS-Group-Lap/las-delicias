---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DeliveryStopsMap from "@/components/DeliveryStopsMap.tsx";
import DeliverySchedule from "@/components/DeliverySchedule.tsx";
import { site } from "@/data/site.ts";
import { deliveryScheduleByDay } from "@/data/deliveryRoutes.ts";
import { getDictionary, getLocalizedPath } from "@/i18n/utils.ts";
import type { Lang } from "@/i18n/types.ts";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props as Props;
const t = getDictionary(lang);
const path = (base: string) => getLocalizedPath(base, lang);
---

<BaseLayout lang={lang} title={t.meta.delivery.title} description={t.meta.delivery.description}>
  <main id="main-content">
  <section class="mx-auto max-w-screen-xl px-6 pb-12 pt-20 md:pb-16 md:pt-28">
    <p class="mb-6 flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
      <span class="inline-block h-px w-8 bg-ink/40"></span>
      {t.delivery.kicker}
    </p>
    <h1 class="max-w-[22ch] text-balance font-serif text-5xl leading-[0.95] md:text-6xl">
      {t.delivery.heading} <span class="italic text-accent">{t.delivery.headingAccent}</span>
    </h1>
    <p class="mt-6 max-w-[62ch] leading-relaxed text-faded">{t.delivery.intro}</p>
  </section>

  <div class="mx-auto max-w-screen-xl px-6 pb-16">
    <div class="rounded-[min(1vw,12px)] bg-paper p-6 text-sm leading-relaxed md:p-8">
      <p class="font-medium text-ink">{t.delivery.calloutStrong}</p>
      <p class="mt-4 text-[11px] uppercase tracking-[0.3em] text-faded">{t.delivery.phonesTitle}</p>
      <div class="mt-3 flex flex-wrap gap-4">
        {
          site.deliveryPhones.map((phone) => (
            <a href={phone.href} class="font-serif text-xl transition-colors hover:text-accent">
              {phone.display}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <section class="mx-auto max-w-screen-xl border-t border-line px-6 pt-12">
    <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-faded">{t.delivery.scheduleTitle}</p>
    <p class="mb-8 max-w-[52ch] text-sm leading-relaxed text-faded">{t.delivery.scheduleNote}</p>
    <DeliverySchedule
      client:visible
      schedule={deliveryScheduleByDay}
      lang={lang}
      labels={{
        viewByDay: t.delivery.viewByDay,
        viewByCity: t.delivery.viewByCity,
        today: t.delivery.today,
        citySelectDefault: t.delivery.citySelectDefault,
        cityHint: t.delivery.cityHint,
        cityResultLabel: t.delivery.cityResultLabel,
      }}
    />
  </section>

  <section class="mx-auto max-w-screen-xl border-t border-line px-6 pt-12">
    <p class="mb-8 text-[11px] uppercase tracking-[0.3em] text-faded">{t.delivery.mapTitle}</p>
    <div class="h-[420px] overflow-hidden rounded-[min(1vw,12px)] ring-1 ring-line md:h-[520px]">
      <DeliveryStopsMap
        client:visible
        bakeryLabel={t.delivery.mapBakeryLabel}
        daysLabel={t.delivery.mapStopDaysLabel}
        stopNote={t.delivery.mapStopNote}
        lang={lang}
      />
    </div>
  </section>

  <section id="wholesale" class="mx-auto mt-24 max-w-screen-xl scroll-mt-24 border-t border-line px-6 pt-12">
    <div class="rounded-[min(1vw,12px)] bg-paper p-8 md:p-10">
      <p class="mb-2 text-[11px] uppercase tracking-[0.3em] text-faded">{t.delivery.wholesaleKicker}</p>
      <h2 class="max-w-[26ch] text-balance font-serif text-3xl leading-[1.05] md:text-4xl">
        {t.delivery.wholesaleHeading} <span class="italic text-accent">{t.delivery.wholesaleHeadingAccent}</span>
      </h2>
      <p class="mt-4 max-w-[56ch] leading-relaxed text-faded">{t.delivery.wholesaleBody}</p>
      <div class="mt-6 flex flex-wrap items-center gap-4">
        <a
          href={site.deliveryPhones[0].href}
          class="inline-flex items-center justify-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
        >
          {t.delivery.wholesaleCta} — {site.deliveryPhones[0].display}
        </a>
        <a
          href={path("/wholesale")}
          class="inline-flex items-center gap-3 text-[11px] uppercase tracking-[0.2em] text-ink underline underline-offset-4 transition-colors hover:text-accent"
        >
          {t.home.wholesaleLink} →
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto mb-32 mt-24 max-w-screen-xl border-t border-line px-6 pt-12">
    <div class="grid items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-7">
        <h2 class="max-w-[22ch] text-balance font-serif text-3xl leading-[1.02] md:text-5xl">
          {t.delivery.endingHeading}
        </h2>
        <p class="mt-4 max-w-[48ch] leading-relaxed text-faded">{t.delivery.endingBody}</p>
      </div>
      <div class="flex flex-col flex-wrap gap-4 sm:flex-row md:col-span-5 md:justify-end">
        <a
          href={site.deliveryPhones[0].href}
          class="inline-flex items-center justify-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
        >
          {t.delivery.ctaConfirm}
        </a>
        <a
          href={path("/menu")}
          class="inline-flex items-center justify-center gap-3 rounded-full px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-ink ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
        >
          {t.common.viewMenu}
        </a>
        <a
          href={site.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 rounded-full px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-ink ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
        >
          {t.common.getDirections} →
        </a>
      </div>
    </div>
  </section>
  </main>
</BaseLayout>
