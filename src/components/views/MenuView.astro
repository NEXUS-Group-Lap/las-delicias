---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { menuCategories } from "@/data/menu.ts";
import { site } from "@/data/site.ts";
import { getDictionary } from "@/i18n/utils.ts";
import type { Lang } from "@/i18n/types.ts";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props as Props;
const t = getDictionary(lang);
---

<BaseLayout lang={lang} title={t.meta.menu.title} description={t.meta.menu.description}>
  <main id="main-content">
  <section class="mx-auto max-w-screen-xl px-6 pb-10 pt-20 md:pb-14 md:pt-28">
    <p class="mb-6 flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
      <span class="inline-block h-px w-8 bg-ink/40"></span>
      {t.menuPage.kicker}
    </p>
    <h1 class="max-w-[20ch] text-balance font-serif text-5xl leading-[0.95] md:text-6xl">
      {t.menuPage.heading} <span class="italic text-accent">{t.menuPage.headingAccent}</span>
    </h1>
    <p class="mt-6 max-w-[56ch] leading-relaxed text-faded">{t.menuPage.sub}</p>
    <p class="mt-4 max-w-[56ch] text-sm leading-relaxed text-faded">{t.menuPage.pricesNote}</p>
  </section>

  <div class="mx-auto max-w-screen-xl px-6 pb-32">
    <nav
      class="sticky top-16 z-40 -mx-6 flex flex-wrap gap-2 border-y border-line bg-base/95 px-6 py-4 backdrop-blur-md"
      aria-label={t.menuPage.jumpNavLabel}
    >
      {
        menuCategories.map((category) => (
          <a href={`#${category.id}`} class="menu-chip">
            {category.name[lang]}
          </a>
        ))
      }
    </nav>

    <div class="space-y-20 pt-16">
      {
        menuCategories.map((category) => (
          <section id={category.id} class="scroll-mt-36 border-t border-line pt-10">
            <div class="mb-8 max-w-[60ch]">
              <h2 class="font-serif text-3xl md:text-4xl">{category.name[lang]}</h2>
              {category.note && (
                <p class="mt-3 text-sm leading-relaxed text-faded">{category.note[lang]}</p>
              )}
            </div>
            <ul class="grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-2 lg:grid-cols-3">
              {category.items.map((item) => (
                <li class="border-b border-line py-3 text-sm leading-relaxed">{item}</li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <section class="mt-24 flex flex-col items-start gap-6 border-t border-line pt-12 sm:flex-row sm:items-center sm:justify-between">
      <p class="max-w-[40ch] text-balance font-serif text-2xl leading-tight md:text-3xl">
        {t.menuPage.bottomHeading} <span class="italic text-accent">{t.menuPage.bottomHeadingAccent}</span>
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href={site.phone.href}
          class="inline-flex items-center justify-center gap-3 rounded-full bg-ink px-6 py-3.5 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
        >
          {t.common.callNow}
        </a>
        <a
          href={site.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 rounded-full px-6 py-3.5 text-[11px] font-medium uppercase tracking-[0.2em] text-ink ring-1 ring-line transition-colors hover:bg-accent hover:text-[var(--color-base)] hover:ring-accent"
        >
          {t.common.getDirections} →
        </a>
      </div>
    </section>
  </div>

  <style>
    .menu-chip {
      border-radius: 9999px;
      padding: 0.375rem 1rem;
      font-size: 0.75rem;
      font-weight: 500;
      line-height: 1rem;
      color: var(--color-ink);
      box-shadow: inset 0 0 0 1px var(--color-line);
      transition:
        background-color 180ms ease,
        color 180ms ease;
      white-space: nowrap;
    }

    .menu-chip:hover {
      background-color: var(--color-accent);
      color: var(--color-base);
    }
  </style>
  </main>
</BaseLayout>
