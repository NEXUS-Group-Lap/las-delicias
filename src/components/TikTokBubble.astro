---
import { site } from "@/data/site.ts";
import type { Lang } from "@/i18n/types.ts";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props as Props;

const tiktokLabel = lang === "es" ? "Síguenos en TikTok" : "Follow us on TikTok";
const handle = site.social.tiktokHandle;
const callLabel = lang === "es" ? "Llamar ahora" : "Call now";
---

<div class="fixed bottom-5 right-5 z-40 flex flex-col items-end gap-3 sm:bottom-6 sm:right-6">
  <a
    href={site.phone.href}
    aria-label={callLabel}
    class="group flex items-center gap-3 rounded-full bg-ink px-3 py-3 text-[var(--color-base)] shadow-lg shadow-black/20 transition-colors hover:bg-accent"
  >
    <span class="flex h-6 w-6 shrink-0 items-center justify-center">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
    </span>
    <span
      class="max-w-0 overflow-hidden whitespace-nowrap text-[11px] font-medium uppercase tracking-[0.15em] opacity-0 transition-all duration-300 ease-out group-hover:max-w-[10rem] group-hover:opacity-100 group-focus-visible:max-w-[10rem] group-focus-visible:opacity-100"
    >
      {site.phone.display}
    </span>
  </a>

  <a
    href={site.social.tiktok}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={tiktokLabel}
    class="tiktok-bubble group relative flex items-center gap-3 rounded-full bg-ink px-3 py-3 text-[var(--color-base)] shadow-lg shadow-black/20"
  >
    <span class="tiktok-ring pointer-events-none absolute inset-0 rounded-full bg-[#25F4EE]/50"></span>
    <span class="tiktok-ring pointer-events-none absolute inset-0 rounded-full bg-[#FE2C55]/40 [animation-delay:1s]"></span>
    <span class="relative flex h-6 w-6 shrink-0 items-center justify-center">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
        <path d="M16.6 5.82c-.9-.66-1.53-1.66-1.7-2.82H12.2v13.6c0 1.32-1.06 2.4-2.38 2.4a2.39 2.39 0 0 1-2.38-2.4 2.39 2.39 0 0 1 2.38-2.4c.24 0 .48.04.7.1v-2.83a5.2 5.2 0 0 0-.7-.05 5.19 5.19 0 0 0-5.18 5.18A5.19 5.19 0 0 0 9.82 22 5.19 5.19 0 0 0 15 16.82V9.4a8.13 8.13 0 0 0 4.7 1.5V8.1a5.4 5.4 0 0 1-3.1-2.28z"></path>
      </svg>
    </span>
    <span
      class="relative max-w-0 overflow-hidden whitespace-nowrap text-[11px] font-medium uppercase tracking-[0.15em] opacity-0 transition-all duration-300 ease-out group-hover:max-w-[10rem] group-hover:opacity-100 group-focus-visible:max-w-[10rem] group-focus-visible:opacity-100"
    >
      {handle}
    </span>
  </a>
</div>

<style>
  .tiktok-ring {
    animation: delivery-pulse 2.6s ease-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .tiktok-ring {
      display: none;
    }
  }
</style>
